
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * UdyamRakshak Security Rules
     */

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isExistingUserAuthorized() {
      return isSignedIn() && resource != null;
    }

    // --- Financial Module Rules ---

    match /financials/{monthId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isExistingUserAuthorized();
    }

    match /startupProfile/main {
      allow get: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /expenseCategories/{categoryId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isExistingUserAuthorized();
    }

    match /expenses/{expenseId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isExistingUserAuthorized();
    }

    match /rounds/{roundId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isExistingUserAuthorized();
    }

    match /investors/{investorId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.roundId != null;
      allow update: if isExistingUserAuthorized() && request.resource.data.roundId == resource.data.roundId;
      allow delete: if isExistingUserAuthorized();
    }

    match /leadership/{memberId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isExistingUserAuthorized();
    }

    match /capitalStructure/main {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isExistingUserAuthorized();
    }

    match /budgets/{monthId} {
      allow get, list: if isSignedIn();
      allow write: if isSignedIn();
    }

    // --- Execution Module Rules ---

    match /projects/{projectId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isExistingUserAuthorized();
    }

    match /tasks/{taskId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isExistingUserAuthorized();
      
      match /weeklyUpdates/{updateId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isExistingUserAuthorized();
      }
    }

    // --- Schedule & Documents Rules ---

    match /schedule/{blockId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isExistingUserAuthorized();
    }

    match /documents/{docId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isExistingUserAuthorized();
    }
  }
}
