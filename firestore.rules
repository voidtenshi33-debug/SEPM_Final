
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * UdyamRakshak Multi-Tenant Security Rules
     */

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Tenant Isolation Rule ---
    // All strategic data is nested under /users/{userId}
    match /users/{userId} {
      
      // Full access to everything under the user's specific path
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
