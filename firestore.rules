/**
 * UdyamRakshak Financial Module - Security Rules Architecture
 * 
 * Core Philosophy:
 * This ruleset implements a multi-tenant security model for a startup financial management platform.
 * Authorization is strictly controlled based on startup membership, ensuring that users can only 
 * access or modify data belonging to a startup where they are authorized members.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * @description Verifies if the authenticated user is a member of the specified startup.
     * For demo purposes, "demo-startup" is accessible to any signed-in user.
     */
    function isMemberOfStartup(startupId) {
      return isSignedIn() && (
        startupId == "demo-startup" ||
        get(/databases/$(database)/documents/startups/$(startupId)).data.members[request.auth.uid] != null
      );
    }

    function isExistingStartupData(resourceData) {
      return resourceData != null && isMemberOfStartup(resourceData.startupId);
    }

    function startupIdIsImmutable() {
      return request.resource.data.startupId == resource.data.startupId;
    }

    // --- COLLECTION RULES ---

    match /startups/{startupId} {
      allow get: if isMemberOfStartup(startupId);
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isMemberOfStartup(startupId);
    }

    match /financials/{monthId} {
      allow get: if isSignedIn() && isMemberOfStartup(resource.data.startupId);
      // Relaxed list for prototype to avoid complex index requirements for simple queries
      allow list: if isSignedIn(); 
      allow create: if isSignedIn() && isMemberOfStartup(request.resource.data.startupId);
      allow update: if isExistingStartupData(resource.data) && startupIdIsImmutable();
      allow delete: if isExistingStartupData(resource.data);
    }

    match /rounds/{roundId} {
      allow get: if isSignedIn() && isMemberOfStartup(resource.data.startupId);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isMemberOfStartup(request.resource.data.startupId);
      allow update: if isExistingStartupData(resource.data) && startupIdIsImmutable();
      allow delete: if isExistingStartupData(resource.data);
    }

    match /investors/{investorId} {
      allow get: if isSignedIn() && isMemberOfStartup(resource.data.startupId);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isMemberOfStartup(request.resource.data.startupId);
      allow update: if isExistingStartupData(resource.data) && startupIdIsImmutable();
      allow delete: if isExistingStartupData(resource.data);
    }

    match /capitalStructure/{startupId} {
      allow get: if isMemberOfStartup(startupId);
      allow list: if isMemberOfStartup(startupId);
      allow create: if isMemberOfStartup(startupId);
      allow update, delete: if isMemberOfStartup(startupId);
    }

    match /leadership/{memberId} {
      allow get: if isSignedIn(); 
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    match /teamMembers/{memberId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    match /projects/{projectId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    match /tasks/{taskId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }
  }
}