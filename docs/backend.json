
{
  "entities": {
    "StartupProfile": {
      "title": "StartupProfile",
      "type": "object",
      "description": "Represents the core information and operational details of the startup.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "industry": { "type": "string" },
        "stage": { "type": "string" },
        "businessType": { "type": "string", "enum": ["Product", "Service", "Hybrid"] },
        "mission": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "industry", "stage", "businessType"]
    },
    "Financials": {
      "title": "Financials",
      "type": "object",
      "description": "Stores monthly financial data and key performance indicators.",
      "properties": {
        "id": { "type": "string" },
        "month": { "type": "string", "description": "Format: YYYY-MM" },
        "netRevenue": { "type": "number" },
        "operatingExpenses": { "type": "number" },
        "cogs": { "type": "number" },
        "unitsSold": { "type": "number" },
        "ordersCount": { "type": "number" },
        "activeClients": { "type": "number" },
        "billableHours": { "type": "number" },
        "retainedClients": { "type": "number" },
        "pipelineValue": { "type": "number" },
        "recurringRevenue": { "type": "number" },
        "oneTimeRevenue": { "type": "number" }
      },
      "required": ["id", "month", "netRevenue", "operatingExpenses"]
    },
    "ExpenseCategory": {
      "title": "ExpenseCategory",
      "type": "object",
      "description": "Defines an expense category type and classification.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["Fixed", "Variable", "R&D"] },
        "color": { "type": "string", "description": "Hex color for UI representation" }
      },
      "required": ["id", "name", "type"]
    },
    "Expense": {
      "title": "Expense",
      "type": "object",
      "description": "An individual expense record linked to a category.",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "number" },
        "categoryId": { "type": "string" },
        "month": { "type": "string", "description": "Format: YYYY-MM" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date" }
      },
      "required": ["id", "amount", "categoryId", "month"]
    },
    "LeadershipMember": {
      "title": "LeadershipMember",
      "type": "object",
      "description": "Represents a member of the startup's leadership team with equity holdings.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "title": { "type": "string", "description": "e.g., CEO, CTO, CFO" },
        "responsibility": { "type": "string" },
        "equityPct": { "type": "number" },
        "vestingYears": { "type": "number" },
        "vestingStartDate": { "type": "string", "format": "date" },
        "vestingEndDate": { "type": "string", "format": "date" },
        "inviteStatus": { "type": "string", "enum": ["Pending", "Accepted"] }
      },
      "required": ["id", "name", "title", "equityPct"]
    },
    "Round": {
      "title": "Round",
      "type": "object",
      "description": "Manages details for each funding round.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "preMoneyValuation": { "type": "number" },
        "postMoneyValuation": { "type": "number" },
        "amountRaised": { "type": "number" },
        "equityDilutedPct": { "type": "number" },
        "roundDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "amountRaised", "equityDilutedPct"]
    },
    "Investor": {
      "title": "Investor",
      "type": "object",
      "description": "Contains details about individual investors.",
      "properties": {
        "id": { "type": "string" },
        "roundId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "investmentAmount": { "type": "number" },
        "equityPct": { "type": "number" },
        "tenureYears": { "type": "number" },
        "dealStartDate": { "type": "string", "format": "date" },
        "dealEndDate": { "type": "string", "format": "date" },
        "loyalty": { "type": "boolean" }
      },
      "required": ["id", "roundId", "name", "equityPct"]
    },
    "CapitalStructure": {
      "title": "CapitalStructure",
      "type": "object",
      "description": "Singleton entity for aggregated equity distribution.",
      "properties": {
        "id": { "type": "string" },
        "founderEquityPct": { "type": "number" },
        "esopEquityPct": { "type": "number" },
        "totalInvestorEquityPct": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "founderEquityPct", "esopEquityPct", "totalInvestorEquityPct"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "startupProfile": {
      "schema": "#/backend/entities/StartupProfile",
      "description": "The foundational profile document for the startup."
    },
    "leadership": {
      "schema": "#/backend/entities/LeadershipMember",
      "description": "Collection of leadership members for the startup."
    },
    "financials": {
      "schema": "#/backend/entities/Financials",
      "description": "Monthly financial records."
    },
    "expenseCategories": {
      "schema": "#/backend/entities/ExpenseCategory",
      "description": "Defined expense categories."
    },
    "expenses": {
      "schema": "#/backend/entities/Expense",
      "description": "Individual expense records."
    },
    "rounds": {
      "schema": "#/backend/entities/Round",
      "description": "Funding rounds."
    },
    "investors": {
      "schema": "#/backend/entities/Investor",
      "description": "Investor participation."
    },
    "capitalStructure": {
      "schema": "#/backend/entities/CapitalStructure",
      "description": "Aggregated cap table singleton."
    }
  }
}
