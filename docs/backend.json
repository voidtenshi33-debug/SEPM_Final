
{
  "entities": {
    "Financial": {
      "title": "Financial",
      "type": "object",
      "description": "Monthly financial performance data.",
      "properties": {
        "id": { "type": "string", "description": "YYYY-MM format" },
        "grossRevenue": { "type": "number" },
        "discounts": { "type": "number" },
        "netRevenue": { "type": "number" },
        "operatingExpenses": { "type": "number" },
        "cogs": { "type": "number" },
        "unitsSold": { "type": "number" },
        "ordersCount": { "type": "number" },
        "activeClients": { "type": "number" },
        "totalClients": { "type": "number" },
        "retainedClients": { "type": "number" },
        "billableHours": { "type": "number" },
        "recurringRevenue": { "type": "number" },
        "oneTimeRevenue": { "type": "number" },
        "dateRecorded": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "grossRevenue", "netRevenue", "operatingExpenses"]
    },
    "StartupProfile": {
      "title": "StartupProfile",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "businessType": { "type": "string", "enum": ["Product", "Service", "Hybrid"] },
        "industry": { "type": "string" },
        "teamSize": { "type": "number" },
        "mission": { "type": "string" },
        "governancePin": { "type": "string", "description": "A 4-digit secret PIN for sensitive financial operations." }
      }
    },
    "ExpenseCategory": {
      "title": "ExpenseCategory",
      "type": "object",
      "description": "Categories for business expenses.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["Fixed", "Variable", "R&D"] },
        "color": { "type": "string" }
      },
      "required": ["name", "type"]
    },
    "Expense": {
      "title": "Expense",
      "type": "object",
      "description": "Individual expense records.",
      "properties": {
        "id": { "type": "string" },
        "monthId": { "type": "string", "description": "YYYY-MM" },
        "categoryId": { "type": "string" },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["monthId", "categoryId", "amount"]
    },
    "Leadership": {
      "title": "Leadership",
      "type": "object",
      "description": "Key team members with equity stakes.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "title": { "type": "string" },
        "responsibility": { "type": "string" },
        "equityPct": { "type": "number" },
        "vestingYears": { "type": "number" },
        "vestingStartDate": { "type": "string", "format": "date" },
        "vestingEndDate": { "type": "string", "format": "date" },
        "inviteStatus": { "type": "string", "enum": ["Pending", "Active"] }
      },
      "required": ["name", "title", "equityPct"]
    },
    "Round": {
      "title": "Round",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "preMoneyValuation": { "type": "number" },
        "postMoneyValuation": { "type": "number" },
        "amountRaised": { "type": "number" },
        "equityDilutedPct": { "type": "number" },
        "roundType": { "type": "string", "enum": ["Equity", "Debt", "Convertible", "SAFE"] },
        "status": { "type": "string", "enum": ["Open", "Closed"] },
        "roundDate": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "amountRaised", "equityDilutedPct"]
    },
    "Investor": {
      "title": "Investor",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "roundId": { "type": "string" },
        "name": { "type": "string" },
        "investmentAmount": { "type": "number" },
        "equityPct": { "type": "number" },
        "tenureYears": { "type": "number" },
        "dealStartDate": { "type": "string", "format": "date" },
        "dealEndDate": { "type": "string", "format": "date" },
        "loyalty": { "type": "boolean" },
        "status": { "type": "string", "enum": ["Active", "Cancelled", "Exited"], "default": "Active" },
        "cancelledAt": { "type": "string", "format": "date-time" },
        "cancelledBy": { "type": "string" },
        "cancellationReason": { "type": "string" }
      },
      "required": ["name", "investmentAmount", "equityPct", "roundId"]
    },
    "CapitalStructure": {
      "title": "CapitalStructure",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "founderPct": { "type": "number" },
        "esopPct": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["founderPct", "esopPct"]
    },
    "Budget": {
      "title": "Budget",
      "type": "object",
      "description": "Monthly budget allocations.",
      "properties": {
        "id": { "type": "string", "description": "YYYY-MM" },
        "categoryBudgets": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "categoryId": { "type": "string" },
              "budgetAmount": { "type": "number" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "categoryBudgets"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "financials/{monthId}": { "schema": "Financial", "description": "Monthly financial snapshots." },
    "startupProfile/main": { "schema": "StartupProfile", "description": "Core startup information." },
    "expenseCategories/{categoryId}": { "schema": "ExpenseCategory", "description": "Business expense categories." },
    "expenses/{expenseId}": { "schema": "Expense", "description": "Individual expense tracking entries." },
    "leadership/{memberId}": { "schema": "Leadership", "description": "Core team equity tracking." },
    "rounds/{roundId}": { "schema": "Round", "description": "Funding round history." },
    "investors/{investorId}": { "schema": "Investor", "description": "Investor cap table entries." },
    "capitalStructure/main": { "schema": "CapitalStructure", "description": "Global cap table settings." },
    "budgets/{monthId}": { "schema": "Budget", "description": "Monthly budget allocations." }
  }
}
